@using Microsoft.AspNetCore.Authentication.Cookies
@using Microsoft.AspNetCore.Identity;
@inject SignInManager<UserModel> SignInManager
@model DndCompanion.Models.CharacterModel

@{
    ViewData["Title"] = "Character";
    bool isOwner = false;
    bool isSignedIn = SignInManager.IsSignedIn(User);
    if(Model != null)
    {
        isOwner = isSignedIn && Model.Owner.UserName == User.Identity.Name;
    }
}

<div class="container mt-4">
    @if(Model == null)
    {
        <h2 class="text-center">You do not have access to this character or it does not exist.</h2>
        <div class="text-center">
            <a asp-controller="Characters" asp-action="Index" class="text-decoration-none mt-3">Back to Characters</a>
        </div>
        return;
    }
    <h1>Character: @Model.Name</h1>

    @if (Model.AvatarImage != null && Model.AvatarImage.Length > 0)
    {
        <img src="data:image/jpeg;base64,@Convert.ToBase64String(Model.AvatarImage)" alt="Avatar" class="img-thumbnail mb-3" width="200" height="200" />
    }

    <p><strong>Description:</strong> @Model.Description</p>
    <p><strong>Created At:</strong> @Model.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</p>
    <p><strong>Owner:</strong> @Model.Owner?.UserName</p>
    <div class="text-center">
        <a asp-controller="Characters" asp-action="Index" class="text-decoration-none mt-3">Back</a>
    </div>
    @if(isOwner && Model.CharacterCampaigns.Count()>0)
    {
        <div>
        <h2>Assigned to campaings</h2>
        <table class="table table-bordered">
            <thead class="table-light">
                <tr>
                    <th>Name</th>
                    <th>Description</th>
                    <th>IsPublic</th>
                    <th>CreatedAt</th>
                    <th>Owner</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var characterCampaign in Model.CharacterCampaigns)
                {
                    <tr>
                        <td><a asp-controller="Campaign" asp-action="Index" asp-route-id="@characterCampaign.Campaign.Id">@characterCampaign.Campaign.Name</a></td>
                        <td>@characterCampaign.Campaign.Description</td>
                        <td>@characterCampaign.Campaign.Public</td>
                        <td>@characterCampaign.Campaign.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                        <td>@characterCampaign.Campaign.UsersCampaigns.Where(x => x.IsOwner).FirstOrDefault()?.User?.UserName</td>
                        <td><a asp-controller="Campaign" asp-action="UnassignCharacter" asp-route-campaignId="@characterCampaign.CampaignId" asp-route-characterId="@Model.Id" class="btn btn-danger btn-sm ms-3">Unassign Character</a></td>
                    </tr>       
                }
            </tbody>
        </table>
        </div>
    }
</div>
