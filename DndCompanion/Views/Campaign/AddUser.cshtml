@model DndCompanion.ViewModels.AddUserToCampaingViewModel

<div class="container">
    <h2>Add User to Campaign</h2>
    <form asp-action="AddUser" method="post" asp-route-campaignId="@ViewBag.CampaignId">
        <div class="mb-3">
            <label asp-for="UserName" class="form-label">Username</label>
            <input asp-for="UserName" class="form-control" />
            <span asp-validation-for="UserName" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Content" class="form-label">Content</label>
            <textarea asp-for="Content" class="form-control" /> </textarea>
            <span asp-validation-for="Content" class="text-danger"></span>
        </div>
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })
        <button type="submit" class="btn btn-primary">Add User</button>
    </form>
    <div class="mt-3">
        <a asp-controller="Campaign" asp-action="Index" asp- asp-route-id="@ViewBag.CampaignId" class="text-decoration-none mt-3">Back to Campaigns</a>
    </div>
</div>

@section Scripts {
    @{
    await Html.RenderPartialAsync("_ValidationScriptsPartial.cshtml");
    }
}